# Database (PostgreSQL, e.g. RDS) — use PG* vars to support password rotation
PGHOST=your-db-host.rds.amazonaws.com
PGPORT=5432
PGUSER=postgres
PGPASSWORD=""
PGDATABASE=image_generation
PGSSLMODE=require

# Clerk Auth (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AWS S3 (Image Storage)
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Image Generation API (Express service). Used only by the server-side proxy (/api/v1/image-generation/*).
# The browser never calls the backend directly; all requests go through the proxy.
# BASE_API_HOSTNAME=http://localhost:3001

# Optional: external catalog API (defaults to bondxlowes). Used by /api/v1/products and /api/v1/catalog.
# CATALOG_PRODUCTS_URL=https://api.bondxlowes.com/catalog/v3/products?perPage=100000
# CATALOG_BASE_URL=https://api.bondxlowes.com/catalog/v3/products

# Debug: log image fetch URLs, sizes, and payload sent to Gemini (set to 1 or true)
# DEBUG_GEMINI_IMAGES=1
