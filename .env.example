# Image-generation service backend URL (server-side only, never exposed to client)
BASE_API_HOSTNAME=http://localhost:3001

# Clerk Auth (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AWS S3 (Image Storage — used by the upload route)
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
