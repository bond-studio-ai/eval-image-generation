# Database (Neon)
DATABASE_URL=postgresql://neondb_owner:...@ep-xxx.c-3.us-west-2.aws.neon.tech/neondb?sslmode=require

# Clerk Auth (get keys from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AWS S3 (Image Storage)
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Debug: log image fetch URLs, sizes, and payload sent to Gemini (set to 1 or true)
# DEBUG_GEMINI_IMAGES=1
